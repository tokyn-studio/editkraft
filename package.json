{
  "name": "editkraft-oss",
  "version": "0.0.0",
  "private": true,
  "description": "Editkraft Open Source – Schema, Renderer, Registry, CLI",
  "license": "MIT",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.5.4",
    "typescript": "^5.9.0"
  }
}
